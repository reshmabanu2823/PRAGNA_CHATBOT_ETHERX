# Backend environment variables (set these in Render dashboard)
GROQ_API_KEY=your_groq_api_key_here
SERPER_API_KEY=your_serper_api_key_here
NEWS_API_KEY=your_newsapi_key_here
FLASK_DEBUG=False
FLASK_PORT=10000
GROQ_MODEL=llama-3.1-8b-instant
SERPER_ENABLED=True
NEWS_ENABLED=True

# JWT Authentication (IMPORTANT: Change this in production!)
JWT_SECRET=your-super-secure-random-jwt-key-change-me-in-production
JWT_EXPIRATION_DAYS=7

# =====================================================================
# KEEPING MODELS UP-TO-DATE - RAG KNOWLEDGE BASE UPDATES
# Automatically fetches latest news to keep chatbot current
# Solves the problem of model training cutoff (December 2023)
# =====================================================================

# Enable/disable automatic RAG updates
RAG_AUTO_UPDATE_ENABLED=True

# How often to update (in hours) - e.g., 6 = every 6 hours
RAG_UPDATE_INTERVAL_HOURS=6

# What time to start daily updates (24-hour format, e.g., "02" = 2 AM)
RAG_UPDATE_START_HOUR=02

# Topics to automatically track and update (comma-separated)
RAG_UPDATE_TOPICS=latest technology news,AI developments,Python updates,machine learning,web development,cybersecurity,data science,cloud computing

# Number of documents to fetch per update cycle
RAG_UPDATE_BATCH_SIZE=10

# Clear old documents before adding new ones (keeps knowledge fresh)
RAG_CLEAR_BEFORE_UPDATE=False

# =====================================================================
# With default settings:
# - Knowledge base updates automatically every 6 hours
# - Fetches latest technology and AI news
# - ~60 new articles added per day
# - Makes current information available to chatbot
# Result: Users get 2026 information, not 2023! 🎉
# =====================================================================
