# ===================================================================
# EtherXChatBot Backend - Production Environment Configuration
# ===================================================================
# This is a template for production deployment
# Copy values from backend/.env.example and fill in with real values
# IMPORTANT: Never commit this file to version control!
#           Use your platform's secret management instead

# ===================================================================
# FLASK SERVER CONFIGURATION
# ===================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=False                    # ⚠️ MUST BE FALSE IN PRODUCTION

# ===================================================================
# LLM PROVIDER SELECTION
# ===================================================================
LLM_PROVIDER=ollama_only             # or "standard" with fallbacks

# ===================================================================
# OLLAMA CONFIGURATION (LOCAL)
# ===================================================================
OLLAMA_ENABLED=True
OLLAMA_API_URL=http://ollama:11434   # Use service name in Docker
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# ===================================================================
# API KEY CREDENTIALS (KEEP SECURE!)
# ===================================================================
# These are fallback providers - Ollama is primary
GROQ_API_KEY=sk_...                  # From https://console.groq.com
OPENAI_API_KEY=sk-...                # From https://platform.openai.com
SERPER_API_KEY=...                   # From https://serper.dev
NEWS_API_KEY=...                     # From https://newsapi.org
RUNWAY_API_KEY=...                   # From https://runwayml.com (optional)

# ===================================================================
# SECURITY SETTINGS
# ===================================================================
DEVELOPMENT_MODE=False               # ⚠️ MUST BE FALSE
JWT_SECRET=your-very-long-random-secret-key-here-change-this

# ===================================================================
# IMAGE GENERATION
# ===================================================================
IMAGE_GENERATION_ENABLED=True
IMAGE_PROVIDER=auto
IMAGE_FALLBACK_PROVIDER_ENABLED=True

# ===================================================================
# DATABASE
# ===================================================================
DATABASE_URL=postgresql://user:password@postgres:5432/etherxchatbot

# ===================================================================
# DEPLOYMENT NOTES
# ===================================================================
# For Docker Compose:
#   - OLLAMA_API_URL should be: http://ollama:11434
#   - DATABASE_URL should use service name: postgres:5432
#
# For Cloud Platforms (Render, Railway, etc):
#   - Use environment variable dashboard
#   - Set OLLAMA_API_URL to your external Ollama URL
#   - Use managed database if possible
#
# For Local systemd:
#   - Use http://localhost:11434 for OLLAMA_API_URL
#   - Use local database path for SQLite
